# Copia este ficheiro para .env e preenche com os dados do teu projeto Supabase
# (Project Settings > API)

VITE_SUPABASE_URL=https://teu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=a_tua_anon_key_aqui

# Chave VAPID pública (para notificações push). Gera o par com:
#   npx web-push generate-vapid-keys
# A chave PRIVADA vai só para os secrets da Edge Function (nunca no frontend).
VITE_VAPID_PUBLIC_KEY=
